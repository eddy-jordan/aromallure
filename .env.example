# Copy this file to .env and fill in your real values.
# .env is in .gitignore so it is never committed to GitHub.

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key from resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here

# Must match a verified sender/domain on Resend.
# Once aromallure.store is verified on Resend, use this:
EMAIL_FROM=Aromallure <hello@aromallure.store>

# ── Payments (Paystack) ──────────────────────────────────────────────────────
# Get from dashboard.paystack.com → Settings → API Keys
# Use test keys (pk_test_... / sk_test_...) during development
# Switch to live keys (pk_live_... / sk_live_...) once compliance is approved
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_SECRET_KEY=sk_test_your_key_here

# ── Local development defaults ───────────────────────────────────────────────
# Leave these as-is for local development
DEBUG=True
SECRET_KEY=local-dev-secret-key-replace-in-production

# ── Media files (Cloudinary) ─────────────────────────────────────────────────
# Get from cloudinary.com → Dashboard → API Keys
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
